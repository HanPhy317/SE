# 环境变量配置（复制为 .env 后修改）
# 部署到 Linux 时: cp .env.example .env  然后编辑 .env

# MySQL 密码
MYSQL_ROOT_PASSWORD=root

# Backend JWT 密钥（生产环境务必修改为随机字符串）
SECRET_KEY=linux-prod-secret-key-change-me

# CORS 允许的来源（nginx 反代后通常只需 http://你的域名 或 http://localhost）
CORS_ORIGINS=http://localhost,http://localhost:80

# 前端端口（默认 80 可改为其他，如 8080）
FRONTEND_PORT=80
